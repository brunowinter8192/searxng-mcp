# SearXNG Project Root
# Required for persistent failure logging (dev/scrape_pipeline/failures.jsonl).
# Set to the absolute path of this repo.
SEARXNG_PROJECT_ROOT=/path/to/your/searxng

# CrossRef Polite Pool
# Optional. When set, appended as &mailto=<value> to CrossRef API requests.
# Polite-pool requests get higher rate limits and better reliability from CrossRef.
# See: https://github.com/CrossRef/rest-api-doc#good-manners--more-reliable-service
SEARXNG_CROSSREF_MAILTO=your-email@example.com
